{
  "expo": {
    "scheme": "echo",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "icon": "./src/assets/icon.png",
    "splash": {
      "image": "./src/assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0015"
    },
    "web": {
      "output": "static"
    },
    "name": "Echo: Proof of Seeker",
    "slug": "com.xelabyte.echo-seeker",
    "android": {
      "package": "com.xelabyte.echo_seeker",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icon.png",
        "backgroundColor": "#0a0015"
      }
    },
    "extra": {
      "eas": {
        "projectId": "5a2721d8-0d1d-401b-8326-ebaa9c9f9416"
      }
    },
    "owner": "importa-holdings-ltd",
    "ios": {
      "bundleIdentifier": "com.xelabyte.echo-seeker",
      "icon": "./src/assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-web-browser",
      "react-native-nfc-manager",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0015",
          "imageWidth": 200
        }
      ]
    ]
  }
}
